# ──────────────────────────────────────────────────────────────────────────────
# AlphaForge environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=alphaforge
POSTGRES_USER=alphaforge
POSTGRES_PASSWORD=alphaforge_dev
DATABASE_URL=postgresql+asyncpg://alphaforge:alphaforge_dev@postgres:5432/alphaforge

# ClickHouse (time-series)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=alphaforge_ts
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Redis (cache + Celery broker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=alphaforge
KAFKA_CONSUMER_GROUP=alphaforge

# JWT / OAuth2
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# RPC providers (per-chain)
ETH_RPC_HTTP=https://eth.llamarpc.com
ETH_RPC_WS=wss://eth.llamarpc.com
BSC_RPC_HTTP=https://bsc-dataseed.binance.org
BSC_RPC_WS=wss://bsc.publicnode.com
POLYGON_RPC_HTTP=https://polygon-rpc.com
POLYGON_RPC_WS=wss://polygon-bor-rpc.publicnode.com
ARBITRUM_RPC_HTTP=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_WS=wss://arbitrum-one.publicnode.com
BASE_RPC_HTTP=https://mainnet.base.org
BASE_RPC_WS=wss://base.publicnode.com
OPTIMISM_RPC_HTTP=https://mainnet.optimism.io
OPTIMISM_RPC_WS=wss://optimism.publicnode.com
AVALANCHE_RPC_HTTP=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_RPC_WS=wss://avalanche-c-chain.publicnode.com
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com
COSMOS_RPC_HTTP=https://rpc.cosmos.network

# Explorer API keys (optional for higher rate limits)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
SNOWTRACE_API_KEY=
SOLSCAN_API_KEY=

# Price oracles
COINGECKO_API_KEY=
DEFILLAMA_BASE=https://api.llama.fi
COINMARKETCAP_API_KEY=

# Notifier channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alphaforge@example.com

# ML
ML_MODEL_DIR=/var/lib/alphaforge/models
ML_DEFAULT_DEVICE=cpu
ML_BATCH_SIZE=64

# QuantCore (Rust)
QUANTCORE_THREADS=4

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_PORT=9090
SENTRY_DSN=

# Auditor
AUDITOR_SOURCIFY_BASE=https://sourcify.dev/server
AUDITOR_MAX_BYTECODE_BYTES=2000000
