{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "services/api",
      "routePrefix": "/_/api"
    },
    "auditor": {
      "entrypoint": "services/auditor",
      "routePrefix": "/_/auditor"
    },
    "cli": {
      "entrypoint": "services/cli",
      "routePrefix": "/_/cli"
    },
    "ingestor": {
      "entrypoint": "services/ingestor",
      "routePrefix": "/_/ingestor"
    },
    "ml": {
      "entrypoint": "services/ml",
      "routePrefix": "/_/ml"
    },
    "notifier": {
      "entrypoint": "services/notifier",
      "routePrefix": "/_/notifier"
    },
    "quantcore": {
      "entrypoint": "services/quantcore",
      "routePrefix": "/_/quantcore"
    },
    "worker": {
      "entrypoint": "services/worker",
      "routePrefix": "/_/worker"
    }
  },
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "pip install fastapi uvicorn orjson pydantic structlog httpx",
  "framework": "vite"
}
